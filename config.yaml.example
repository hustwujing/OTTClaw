# ============================================================
# config.yaml 配置示例
# 复制此文件为 config.yaml，按需修改，可提交到 git（不含密钥）
# 优先级低于系统环境变量和 .env 文件
# ============================================================

# ========== 日志 ==========
log:
  level: info            # debug | info | warn | error
  dir: logs              # 日志目录；空字符串表示只输出到 stdout
  file: app.log          # 日志文件名；空字符串表示只输出到 stdout
  data_max_len: 1200     # 工具调用参数/对话历史的最大打印长度（字符数），0 不截断
