# ============================================================
# OTTClaw 配置示例
# 复制此文件为 .env，填写真实值，不要提交 .env 到 git
# ============================================================

# ========== 服务器 ==========
SERVER_PORT=8080

# ========== JWT 鉴权 ==========
# 生产环境请使用随机长字符串：openssl rand -hex 32
JWT_SECRET=change-me-in-production-secret-key
PROGRESS_LABEL="进度标识"   # 进度事件的 step 标识，前端展示用

# ========== LLM 接入 ==========
# LLM_PROVIDER: openai（默认，兼容所有 OpenAI Chat Completions API）| anthropic
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=
LLM_MODEL=gpt-4o
# Anthropic 必填；OpenAI 可选（默认 8096）
LLM_MAX_TOKENS=8096
# 每分钟最大请求数（令牌桶限速），0 或不设置表示不限制
LLM_RPM=0
# Agent 最大迭代次数，超过则强制结束对话，避免死循环
AGENT_MAX_ITERATIONS=20
# 触发自我进化技能生成所需的最少工具调用轮次，默认 3；设为 0 禁用
SELF_IMPROVING_MIN_TOOL_ITERS=3

# ========== LLM 多节点（负载均衡 round-robin）==========
# 节点 2
LLM_BASE_URL_2=
LLM_API_KEY_2=
LLM_MODEL_2=
LLM_PROVIDER_2=openai
LLM_MAX_TOKENS_2=8096

# 节点 3
LLM_BASE_URL_3=
LLM_API_KEY_3=
LLM_MODEL_3=
LLM_PROVIDER_3=openai
LLM_MAX_TOKENS_3=8096

# 节点 4
LLM_BASE_URL_4=
LLM_API_KEY_4=
LLM_MODEL_4=
LLM_PROVIDER_4=openai
LLM_MAX_TOKENS_4=8096

# ========== nano-banana 图像生成 ==========
NANO_BANANA_API_KEY=
NANO_BANANA_BASE_URL=
NANO_BANANA_MODEL=

# ========== 数据库 ==========
# 选择驱动：sqlite（默认，适合本地开发）| mysql（生产推荐）
DATABASE_DRIVER=sqlite

# --- SQLite（DATABASE_DRIVER=sqlite 时生效）---
DATABASE_PATH=data/data.db

# --- MySQL（DATABASE_DRIVER=mysql 时生效）---
# DATABASE_DRIVER=mysql
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=3306
# DATABASE_NAME=skill_executor
# DATABASE_USER=root
# DATABASE_PASSWORD=your_password_here

# ========== 文件路径 ==========
SKILLS_DIR=skills
ROLE_MD_PATH=config/ROLE.md
TOOL_MD_PATH=config/TOOL.md
UPLOAD_DIR=uploads   # 上传文件根目录
OUTPUT_DIR=output    # 生成文件根目录（图片等）
# 单次上传文件大小上限（字节），超出拒绝；0 不限制，默认 20971520（20 MB）
UPLOAD_MAX_BYTES=20971520

# ========== 日志 ==========
LOG_LEVEL=info
LOG_DIR=             # 不设置则只输出到 stdout
LOG_FILE=            # 不设置则只输出到 stdout
# 日志中工具调用参数/对话历史的最大打印长度，超出截断
LOG_DATA_MAX_LEN=1200

# ========== 对话历史压缩 ==========
MAX_CONTEXT_TOKENS=20000
COMPRESS_KEEP_RECENT=10

# ========== 飞书集成 ==========
FEISHU_ENCRYPT_KEY=          # AES-GCM 加密 AppSecret 的密钥
# 私有部署或代理时修改；默认 https://open.feishu.cn
FEISHU_API_BASE=https://open.feishu.cn
# 飞书侧 spinner 动画刷新间隔（毫秒），默认 800
FEISHU_SPINNER_INTERVAL_MS=800
# 等待用户操作（上传文件等）的超时分钟数，默认 30
FEISHU_PENDING_TIMEOUT_MIN=30

# ========== 用户记忆 ==========
# 用户记忆最大字符数，超出自动压缩，默认 500
USER_MEMORY_MAX_CHARS=500

# ========== 浏览器自动化 ==========
BROWSER_HEADLESS=true
# Node.js Playwright sidecar 监听端口，默认 9222
BROWSER_SERVER_PORT=9222
# Node.js sidecar 脚本路径，默认 browser-server/server.js
BROWSER_SERVER_SCRIPT=browser-server/server.js
# per-user Chrome Profile 根目录；实际路径为 {base}/{userID}，自动按用户隔离 cookie/登录态
BROWSER_USER_DATA_BASE=data/browser-profiles

# ========== 工具执行超时 ==========
TOOL_SCRIPT_TIMEOUT_SEC=120
TOOL_EXEC_TIMEOUT_SEC=3600
TOOL_EXEC_YIELD_MS=15000
TOOL_WEB_FETCH_TIMEOUT_SEC=30
WECOM_WEBHOOK_TIMEOUT_SEC=15

# ========== 工具结果 ==========
# output_file 生成的下载链接有效期（分钟），默认 30
DOWNLOAD_TTL_MIN=60
# 工具结果写入 DB 的最大字节数，超出截断并追加提示；0 不截断，默认 2000
TOOL_RESULT_MAX_DB_BYTES=5000

# 工具调用失败时推送给前端的错误摘要最大字符数，默认 32
TOOL_ERROR_SUMMARY_LEN=1024
# fs(action=read) 文本文件大小上限（字节），超出拒绝读取；0 不限制，默认 524288（512 KB）
FS_READ_MAX_BYTES=204800
# read_file 从 .docx/.pdf/.pptx 提取文本的大小上限（字节）；0 不限制，默认 20971520（20 MB）
READ_FILE_MAX_BYTES=81920
# read_image 读取图片的大小上限（字节），超出自动缩放；0 不限制，默认 5242880（5 MB）
READ_IMAGE_MAX_BYTES=1048576

# ========== Tavily（网络搜索 / 爬取 / 研究）==========
# 从 https://app.tavily.com 获取，供 tvly CLI 使用
TAVILY_API_KEY=
# summarize CLI 反爬回退（配合 --firecrawl auto）；从 https://www.firecrawl.dev 获取，不设置则跳过
FIRECRAWL_API_KEY=
# summarize CLI YouTube 字幕提取备用方案（配合 --youtube auto）；从 https://apify.com 获取，不设置则仅用内置方案
APIFY_API_TOKEN=

# ========== MCP 外接能力 ==========
# MCP server 配置文件路径，默认 config/mcp.json
MCP_CONFIG_PATH=config/mcp.json

# ========== 自进化 ==========
SELF_IMPROVING_MIN_TOOL_ITERS=3
